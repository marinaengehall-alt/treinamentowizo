const mods=[...document.querySelectorAll('.mod')];
mods.forEach(mod=>{
  const head=mod.querySelector('.mod-head');
  const body=mod.querySelector('.mod-body');
  head.addEventListener('click',()=>{
    const open=mod.classList.toggle('open');

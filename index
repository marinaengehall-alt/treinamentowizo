<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prospecção Estratégica — Wizo Academy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --wine:#551e35;
    --wine-deep:#41152a;
    --wine-soft:#6d2c45;
    --navy:#092939;
    --navy-2:#0e3548;
    --gold:#c6b690;
    --gold-bright:#dccba2;
    --paper:#f1f1f1;
    --paper-2:#e7e4de;
    --ink:#1c121a;
    --white:#ffffff;
    --line:rgba(28,18,26,.12);
    --display:'Archivo',system-ui,sans-serif;
    --body:'Hanken Grotesk',system-ui,sans-serif;
    --maxw:1180px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--body);
    color:var(--ink);
    background:var(--paper);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,h4{font-family:var(--display);line-height:1.04;letter-spacing:-.02em;font-weight:800}
  a{color:inherit;text-decoration:none}
  img{max-width:100%}
  ::selection{background:var(--gold);color:var(--wine-deep)}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
  .eyebrow{
    font-family:var(--display);font-weight:700;font-size:.72rem;
    letter-spacing:.28em;text-transform:uppercase;
  }

  /* ---------- LOGO ---------- */
  .logo{font-family:var(--display);font-weight:800;font-size:1.45rem;letter-spacing:-.04em;display:inline-flex;align-items:flex-start;line-height:1}
  .logo .dot{color:var(--gold);position:relative}
  .logo sup{font-size:.42em;font-weight:600;opacity:.7;margin-left:1px;letter-spacing:0}
  .logo .ac{display:inline-block;width:.5em;height:.16em;background:var(--gold);transform:skewX(-22deg);margin-right:.12em;position:relative;top:.18em}

  /* ---------- NAV ---------- */
  nav{
    position:sticky;top:0;z-index:60;
    background:rgba(241,241,241,.82);backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  nav .wrap{display:flex;align-items:center;justify-content:space-between;height:66px}
  nav .logo{color:var(--ink)}
  .nav-links{display:flex;gap:28px;align-items:center;font-weight:500;font-size:.93rem}
  .nav-links a.muted{color:#5a4f57}
  .nav-links a.muted:hover{color:var(--ink)}
  .btn{
    font-family:var(--display);font-weight:700;font-size:.9rem;
    padding:11px 22px;border-radius:2px;border:0;cursor:pointer;
    display:inline-flex;align-items:center;gap:9px;transition:.18s ease;letter-spacing:.01em;
  }
  .btn-gold{background:var(--gold);color:var(--wine-deep)}
  .btn-gold:hover{background:var(--gold-bright);transform:translateY(-1px)}
  .btn-wine{background:var(--wine);color:#fff}
  .btn-wine:hover{background:var(--wine-soft);transform:translateY(-1px)}
  .btn-ghost{background:transparent;border:1.5px solid currentColor}
  .btn-ghost:hover{background:rgba(255,255,255,.08)}
  @media(max-width:780px){.nav-links a.muted{display:none}}

  /* ---------- HERO ---------- */
  .hero{position:relative;background:var(--wine);color:#fff;overflow:hidden}
  .hero::after{
    content:"";position:absolute;inset:0;z-index:0;
    background:
      radial-gradient(900px 500px at 88% -10%, rgba(198,182,144,.18), transparent 60%);
  }
  /* brand grafismo: big diagonal W/Z shapes */
  .hero .grafismo{position:absolute;inset:0;z-index:0;opacity:.5;pointer-events:none}
  .hero .gf{position:absolute;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07)}
  .gf1{width:230px;height:430px;top:-90px;right:6%;transform:skewX(-20deg)}
  .gf2{width:230px;height:430px;top:-40px;right:18%;clip-path:polygon(0 0,100% 0,100% 70%,0 100%);transform:skewX(-20deg)}
  .gf3{width:260px;height:260px;border-radius:50%;bottom:-130px;right:30%;border:1px solid rgba(255,255,255,.08);background:transparent}
  .hero .wrap{position:relative;z-index:2;display:grid;grid-template-columns:1.1fr .9fr;gap:40px;padding-top:64px;padding-bottom:64px;align-items:center}
  .hero .eyebrow{color:var(--gold);margin-bottom:18px}
  .crumb{font-size:.84rem;color:rgba(255,255,255,.55);margin-bottom:22px;font-weight:500}
  .crumb a:hover{color:#fff}
  .hero h1{font-size:clamp(2.5rem,5.2vw,4rem);font-weight:900}
  .hero h1 em{font-style:normal;color:var(--gold)}
  .hero .lede{font-size:1.18rem;color:rgba(255,255,255,.82);margin-top:22px;max-width:34ch}
  .hero-meta{display:flex;flex-wrap:wrap;gap:10px 26px;margin-top:30px;font-size:.92rem;color:rgba(255,255,255,.82);font-weight:500}
  .hero-meta b{font-weight:700;color:#fff}
  .hero-cta{display:flex;gap:14px;flex-wrap:wrap;margin-top:34px;align-items:center}
  .stars{color:var(--gold);letter-spacing:2px}
  .rate{font-size:.86rem;color:rgba(255,255,255,.7)}

  /* hero card: the ascending visual */
  .heroviz{
    position:relative;background:linear-gradient(160deg,var(--navy),var(--navy-2));
    border-radius:6px;padding:30px 28px 26px;
    clip-path:polygon(0 0,100% 0,100% 88%,0 100%);
    box-shadow:0 30px 70px -30px rgba(0,0,0,.6);
  }
  .heroviz .tag{font-family:var(--display);font-weight:700;font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)}
  .heroviz h3{color:#fff;font-size:1.5rem;margin:6px 0 4px;line-height:1.1}
  .heroviz p{font-size:.86rem;color:rgba(255,255,255,.6)}
  .heroviz svg{width:100%;height:auto;display:block;margin-top:8px}

  /* ---------- GENERIC SECTION ---------- */
  section{padding:72px 0}
  .sec-eyebrow{color:var(--wine);margin-bottom:14px}
  .sec-title{font-size:clamp(1.7rem,3.4vw,2.5rem);max-width:20ch}
  .sec-intro{color:#4b4047;font-size:1.05rem;max-width:60ch;margin-top:16px}

  /* layout main + sidebar */
  .layout{display:grid;grid-template-columns:1fr 340px;gap:54px;align-items:start}
  @media(max-width:940px){
    .hero .wrap{grid-template-columns:1fr}
    .heroviz{max-width:520px}
    .layout{grid-template-columns:1fr}
  }

  /* learn grid */
  .learn-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px 34px;margin-top:14px}
  .learn-grid li{list-style:none;display:flex;gap:14px;font-size:1rem}
  .learn-grid .ck{flex:0 0 auto;width:26px;height:26px;background:var(--wine);color:var(--gold);
    display:grid;place-items:center;font-size:.8rem;font-weight:800;border-radius:2px;transform:skewX(-8deg)}
  .learn-grid .ck span{transform:skewX(8deg)}
  @media(max-width:560px){.learn-grid{grid-template-columns:1fr}}

  /* sidebar enroll card */
  .enroll{
    position:sticky;top:90px;background:#fff;border:1px solid var(--line);
    border-radius:4px;overflow:hidden;box-shadow:0 20px 50px -28px rgba(28,18,26,.3);
  }
  .enroll .top{background:var(--navy);color:#fff;padding:26px 24px;position:relative;overflow:hidden}
  .enroll .top::after{content:"";position:absolute;right:-40px;top:-40px;width:140px;height:140px;
    background:rgba(198,182,144,.12);transform:skewX(-20deg)}
  .enroll .price{font-family:var(--display);font-weight:900;font-size:2.2rem;line-height:1}
  .enroll .price small{display:block;font-family:var(--body);font-weight:500;font-size:.8rem;color:rgba(255,255,255,.6);letter-spacing:.04em;margin-bottom:6px}
  .enroll .body{padding:22px 24px}
  .enroll .btn{width:100%;justify-content:center;margin-bottom:10px}
  .enroll ul{list-style:none;margin-top:14px}
  .enroll li{display:flex;gap:11px;padding:9px 0;border-top:1px solid var(--line);font-size:.9rem;color:#473d44}
  .enroll li:first-child{border-top:0}
  .enroll li .i{color:var(--wine);font-weight:800;flex:0 0 auto}
  .guarantee{font-size:.78rem;color:#7a6f76;text-align:center;margin-top:8px}

  /* ---------- TRILHA ---------- */
  .trilha{background:var(--navy);color:#fff;position:relative;overflow:hidden}
  .trilha::before{content:"";position:absolute;top:0;left:0;right:0;height:120px;
    background:var(--paper);clip-path:polygon(0 0,100% 0,100% 0,0 70%)}
  .trilha .wrap{position:relative;z-index:2}
  .trilha .sec-eyebrow{color:var(--gold)}
  .trilha .sec-title{color:#fff}
  .trilha .sec-intro{color:rgba(255,255,255,.66)}
  .progress-head{display:flex;align-items:center;justify-content:space-between;gap:20px;margin:34px 0 8px;flex-wrap:wrap}
  .progress-head .lbl{font-family:var(--display);font-weight:700;letter-spacing:.04em}
  .progress-head .lbl b{color:var(--gold)}
  .pbar{height:8px;background:rgba(255,255,255,.12);border-radius:20px;overflow:hidden}
  .pbar i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--gold),var(--gold-bright));border-radius:20px;transition:width .5s cubic-bezier(.2,.7,.2,1)}

  /* ascending trajectory signature */
  .traj{margin:30px 0 40px}
  .traj svg{width:100%;height:auto;display:block;overflow:visible}
  .traj .track{stroke:rgba(255,255,255,.16);stroke-width:3;fill:none}
  .traj .fill{stroke:var(--gold);stroke-width:3.5;fill:none;stroke-linecap:round;
    stroke-dasharray:1000;stroke-dashoffset:1000;transition:stroke-dashoffset .6s ease}
  .traj .node{fill:var(--navy);stroke:rgba(255,255,255,.3);stroke-width:2}
  .traj .goal{fill:none;stroke:var(--gold);stroke-width:2.5}
  .traj .dot{fill:var(--gold);transition:.6s ease}

  /* modules accordion */
  .mods{margin-top:8px}
  .mod{border:1px solid rgba(255,255,255,.13);border-radius:4px;margin-bottom:12px;background:rgba(255,255,255,.025);overflow:hidden;transition:.2s}
  .mod.open{border-color:rgba(198,182,144,.5);background:rgba(255,255,255,.05)}
  .mod-head{width:100%;text-align:left;background:none;border:0;color:#fff;cursor:pointer;
    display:flex;align-items:center;gap:18px;padding:18px 20px;font-family:inherit}
  .mod-num{font-family:var(--display);font-weight:800;font-size:1rem;color:var(--gold);
    flex:0 0 auto;width:44px;height:44px;display:grid;place-items:center;
    border:1.5px solid rgba(198,182,144,.4);transform:skewX(-9deg)}
  .mod-num span{transform:skewX(9deg)}
  .mod.done .mod-num{background:var(--gold);color:var(--navy);border-color:var(--gold)}
  .mod-ti{flex:1}
  .mod-ti b{font-family:var(--display);font-weight:700;font-size:1.08rem;display:block;letter-spacing:-.01em}
  .mod-ti em{font-style:normal;font-size:.82rem;color:rgba(255,255,255,.5);font-weight:500}
  .mod-chev{transition:.3s;color:rgba(255,255,255,.5);font-size:1.3rem}
  .mod.open .mod-chev{transform:rotate(180deg);color:var(--gold)}
  .mod-body{max-height:0;overflow:hidden;transition:max-height .4s ease}
  .mod-inner{padding:4px 20px 22px 82px}
  .mod-inner p{color:rgba(255,255,255,.78);font-size:.97rem;margin-bottom:14px}
  .mod-inner ul{list-style:none;margin-bottom:14px}
  .mod-inner li{position:relative;padding-left:20px;margin:7px 0;color:rgba(255,255,255,.72);font-size:.93rem}
  .mod-inner li::before{content:"";position:absolute;left:0;top:9px;width:8px;height:8px;background:var(--gold);transform:skewX(-12deg)}
  .mod-check{display:inline-flex;align-items:center;gap:9px;background:none;border:1.5px solid rgba(255,255,255,.25);
    color:#fff;border-radius:2px;padding:8px 16px;cursor:pointer;font-family:var(--display);font-weight:600;font-size:.82rem;transition:.18s}
  .mod-check:hover{border-color:var(--gold);color:var(--gold)}
  .mod.done .mod-check{background:var(--gold);color:var(--navy);border-color:var(--gold)}
  @media(max-width:560px){.mod-inner{padding-left:20px}}

  /* ---------- DICAS ---------- */
  .tips-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:18px}
  .tip{background:#fff;border:1px solid var(--line);border-left:4px solid var(--gold);padding:24px 22px;border-radius:0 4px 4px 0}
  .tip .k{font-family:var(--display);font-weight:700;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--wine)}
  .tip h4{font-size:1.15rem;margin:8px 0 8px}
  .tip p{font-size:.92rem;color:#4b4047}
  @media(max-width:820px){.tips-grid{grid-template-columns:1fr}}

  /* ---------- QUIZ ---------- */
  .quiz{background:linear-gradient(160deg,var(--wine),var(--wine-deep));color:#fff;position:relative;overflow:hidden}
  .quiz::after{content:"";position:absolute;left:-60px;bottom:-60px;width:300px;height:300px;border:1px solid rgba(255,255,255,.08);border-radius:50%}
  .quiz .wrap{position:relative;z-index:2}
  .quiz .sec-eyebrow{color:var(--gold)}
  .quiz .sec-title,.quiz .sec-intro{color:#fff}
  .quiz .sec-intro{color:rgba(255,255,255,.75)}
  .qcard{background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:30px;margin-top:30px;max-width:760px}
  .qcount{font-family:var(--display);font-weight:700;letter-spacing:.04em;color:var(--gold);font-size:.85rem;text-transform:uppercase}
  .qscenario{font-size:.85rem;color:var(--gold-bright);font-weight:600;margin:14px 0 6px;text-transform:uppercase;letter-spacing:.08em}
  .qtext{font-family:var(--display);font-weight:700;font-size:1.4rem;line-height:1.2;margin-bottom:22px}
  .opt{display:block;width:100%;text-align:left;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.16);
    color:#fff;border-radius:4px;padding:15px 18px;margin-bottom:12px;cursor:pointer;font-family:inherit;font-size:.97rem;transition:.16s;display:flex;gap:13px;align-items:flex-start}
  .opt:hover:not(:disabled){border-color:var(--gold);background:rgba(255,255,255,.09)}
  .opt .mk{flex:0 0 auto;width:24px;height:24px;border:1.5px solid rgba(255,255,255,.4);border-radius:2px;display:grid;place-items:center;font-family:var(--display);font-weight:800;font-size:.8rem;transform:skewX(-8deg)}
  .opt .mk span{transform:skewX(8deg)}
  .opt.correct{border-color:#8fd19e;background:rgba(143,209,158,.15)}
  .opt.correct .mk{background:#8fd19e;color:var(--wine-deep);border-color:#8fd19e}
  .opt.wrong{border-color:#e8a0a8;background:rgba(232,160,168,.12)}
  .opt.wrong .mk{background:#e8a0a8;color:var(--wine-deep);border-color:#e8a0a8}
  .opt:disabled{cursor:default}
  .qfb{font-size:.95rem;line-height:1.5;background:rgba(198,182,144,.14);border-left:3px solid var(--gold);
    padding:14px 16px;border-radius:0 3px 3px 0;margin-top:8px;display:none}
  .qfb.show{display:block}
  .qfb b{color:var(--gold-bright)}
  .qnav{display:flex;justify-content:space-between;align-items:center;margin-top:22px;gap:14px}
  .qresult{display:none;text-align:center;padding:12px 0}
  .qresult.show{display:block}
  .qresult .big{font-family:var(--display);font-weight:900;font-size:3rem;color:var(--gold)}

  /* ---------- SCRIPTS ---------- */
  .tabs{display:flex;flex-wrap:wrap;gap:8px;margin:24px 0 22px}
  .tab{font-family:var(--display);font-weight:600;font-size:.9rem;padding:10px 18px;border:1.5px solid var(--line);
    background:#fff;border-radius:2px;cursor:pointer;transition:.16s;color:#5a4f57}
  .tab:hover{border-color:var(--wine)}
  .tab.active{background:var(--wine);color:#fff;border-color:var(--wine)}
  .script{display:none;background:#fff;border:1px solid var(--line);border-radius:4px;overflow:hidden}
  .script.active{display:block}
  .script .sh{background:var(--paper-2);padding:16px 24px;display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}
  .script .sh b{font-family:var(--display);font-weight:700;font-size:1.05rem}
  .script .sh .goal{font-size:.82rem;color:#6b6068}
  .bubble{padding:24px 24px 8px}
  .msg{background:var(--paper);border-radius:3px 14px 14px 14px;padding:14px 18px;margin-bottom:14px;
    font-size:.98rem;max-width:90%;position:relative;border:1px solid var(--line)}
  .msg.alt{background:#fbeef0;border-color:#f0d6dc}
  .msg .who{font-family:var(--display);font-weight:700;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--wine);display:block;margin-bottom:4px}
  .copy-row{padding:0 24px 24px}
  .copy-btn{font-family:var(--display);font-weight:600;font-size:.82rem;background:none;border:1.5px solid var(--line);
    padding:9px 16px;border-radius:2px;cursor:pointer;color:var(--wine);transition:.16s}
  .copy-btn:hover{border-color:var(--wine);background:var(--wine);color:#fff}

  /* ---------- METRICS ---------- */
  .metrics{background:var(--ink);color:#fff;position:relative;overflow:hidden}
  .metrics .sec-eyebrow{color:var(--gold)}
  .metrics .sec-title{color:#fff}
  .metrics .sec-intro{color:rgba(255,255,255,.6)}
  .funnel{display:grid;grid-template-columns:1.1fr 1fr;gap:50px;margin-top:36px;align-items:center}
  .funnel-steps{list-style:none}
  .fstep{display:flex;align-items:center;gap:16px;padding:11px 0;border-bottom:1px solid rgba(255,255,255,.1)}
  .fstep .n{font-family:var(--display);font-weight:800;color:var(--gold);width:30px}
  .fstep b{font-family:var(--display);font-weight:600;flex:1}
  .fstep em{font-style:normal;font-size:.82rem;color:rgba(255,255,255,.5)}
  .kpis{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .kpi{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:24px 22px}
  .kpi .num{font-family:var(--display);font-weight:900;font-size:2.6rem;color:var(--gold);line-height:1}
  .kpi .lab{font-size:.86rem;color:rgba(255,255,255,.66);margin-top:8px}
  @media(max-width:820px){.funnel{grid-template-columns:1fr;gap:36px}}
  @media(max-width:460px){.kpis{grid-template-columns:1fr}}

  /* ---------- ABOUT ---------- */
  .about-card{display:grid;grid-template-columns:auto 1fr;gap:30px;align-items:center;
    background:#fff;border:1px solid var(--line);border-radius:6px;padding:34px;margin-top:30px}
  .badge-w{width:96px;height:96px;background:var(--wine);display:grid;place-items:center;border-radius:4px;flex:0 0 auto}
  .badge-w .logo{color:#fff;font-size:1.6rem}
  .about-card h3{font-size:1.4rem}
  .about-card p{color:#4b4047;margin-top:8px;max-width:62ch}
  @media(max-width:560px){.about-card{grid-template-columns:1fr;text-align:center;justify-items:center}}

  /* ---------- FINAL CTA ---------- */
  .finalcta{background:var(--navy);color:#fff;text-align:center;position:relative;overflow:hidden}
  .finalcta::before{content:"";position:absolute;inset:0;background:radial-gradient(700px 360px at 50% -20%,rgba(198,182,144,.18),transparent 60%)}
  .finalcta .wrap{position:relative;z-index:2}
  .finalcta h2{font-size:clamp(2rem,4.6vw,3.2rem);font-weight:900;max-width:18ch;margin:0 auto}
  .finalcta h2 em{font-style:normal;color:var(--gold)}
  .finalcta p{color:rgba(255,255,255,.7);font-size:1.1rem;margin:18px auto 0;max-width:50ch}

  /* ---------- FOOTER ---------- */
  footer{background:var(--ink);color:rgba(255,255,255,.5);padding:46px 0 40px;font-size:.88rem}
  footer .wrap{display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap}
  footer .logo{color:#fff}
  footer .tagline{color:var(--gold);font-family:var(--display);font-weight:600;font-size:.9rem}

  /* reveal */
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in{opacity:1;transform:none}
  @media(prefers-reduced-motion:reduce){
    *{scroll-behavior:auto!important}
    .reveal{opacity:1;transform:none;transition:none}
    .pbar i,.traj .fill,.traj .dot,.mod-body{transition:none}
  }
  :focus-visible{outline:3px solid var(--gold);outline-offset:2px;border-radius:2px}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="wrap">
    <a href="#top" class="logo" aria-label="Wizo">W<span class="ac"></span>iz<span class="dot">o</span><sup>®</sup></a>
    <div class="nav-links">
      <a class="muted" href="#trilha">Trilha</a>
      <a class="muted" href="#scripts">Scripts</a>
      <a class="muted" href="#teste">Teste seu nível</a>
      <a class="btn btn-wine" href="#inscricao">Começar agora</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero" id="top">
  <div class="grafismo" aria-hidden="true">
    <span class="gf gf1"></span><span class="gf gf2"></span><span class="gf gf3"></span>
  </div>

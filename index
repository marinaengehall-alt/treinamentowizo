/* ---------------- PROGRESS + TRAJECTORY ---------------- */
const done=new Set();
const total=MODULES.length;
const progBar=document.getElementById('progBar');
const progLabel=document.getElementById('progLabel');
const progPct=document.getElementById('progPct');

// build trajectory svg (ascending zigzag with a node per module + goal)
const svg=document.getElementById('trajSvg');
const W=1000,H=150,padL=15,padR=30,baseY=H-18,topY=22;
const pts=[];
for(let i=0;i<total;i++){
  const x=padL+(W-padL-padR-40)*(i/(total-1));
  // zigzag: alternate slight dips while overall ascending
  const t=i/(total-1);
  const jitter=(i%2===0)?6:-6;
  const y=baseY-(baseY-topY)*t+jitter;
  pts.push([x,y]);
}
const goal=[W-padR,topY-4];
const allPts=[...pts,goal];
const pathD="M"+allPts.map(p=>p.join(",")).join(" L");
let svgInner=`<path class="track" d="${pathD}"/><path class="fill" id="trajFill" d="${pathD}"/>`;
pts.forEach((p,i)=>{svgInner+=`<circle class="node" data-i="${i}" cx="${p[0]}" cy="${p[1]}" r="6"/>`;});
svgInner+=`<circle class="goal" cx="${goal[0]}" cy="${goal[1]}" r="10"/><circle class="goal" cx="${goal[0]}" cy="${goal[1]}" r="4" fill="#c6b690"/>`;
svgInner+=`<circle class="dot" id="trajDot" cx="${pts[0][0]}" cy="${pts[0][1]}" r="7"/>`;
svg.innerHTML=svgInner;

const trajFill=document.getElementById('trajFill');
const trajDot=document.getElementById('trajDot');
const fillLen=trajFill.getTotalLength();
trajFill.style.strokeDasharray=fillLen;
trajFill.style.strokeDashoffset=fillLen;

function updateProgress(){
  const c=done.size;
  const pct=Math.round((c/total)*100);
  progBar.style.width=pct+'%';
  progLabel.textContent=`${c} de ${total}`;
  progPct.textContent=pct+'%';
  trajFill.style.strokeDashoffset=fillLen-(fillLen*c/total);
  // move dot along path
  const dotPos=trajFill.getPointAtLength(fillLen*c/total);
  trajDot.setAttribute('cx',dotPos.x);
  trajDot.setAttribute('cy',dotPos.y);
  // light up nodes
  document.querySelectorAll('.traj .node').forEach((nd,idx)=>{
    nd.setAttribute('fill',idx<c?'#c6b690':'#092939');
    nd.setAttribute('stroke',idx<c?'#c6b690':'rgba(255,255,255,.3)');
  });
}

document.querySelectorAll('.mod-check').forEach(btn=>{
  btn.addEventListener('click',e=>{
    e.stopPropagation();
    const i=+btn.dataset.i;
    const mod=mods[i];
    if(done.has(i)){done.delete(i);mod.classList.remove('done');btn.textContent='Marcar como concluído';}
    else{done.add(i);mod.classList.add('done');btn.textContent='✓ Concluído';}
    updateProgress();
  });
});

/* ---------------- QUIZ ---------------- */
const quizArea=document.getElementById('quizArea');
const qProg=document.getElementById('qProg');
const qNext=document.getElementById('qNext');
const quizNav=document.getElementById('quizNav');
const quizResult=document.getElementById('quizResult');
let qi=0,score=0,answered=false;
const LETTERS=['A','B','C','D'];

function renderQ(){
  answered=false;qNext.disabled=true;
  const item=QUIZ[qi];
  qProg.textContent=`Pergunta ${qi+1} de ${QUIZ.length}`;
  qNext.textContent=(qi===QUIZ.length-1)?'Ver resultado →':'Próxima →';
  quizArea.innerHTML=`
    <p class="qscenario">Situação · ${item.scenario}</p>
    <p class="qtext">${item.q}</p>
    <div id="opts">${item.opts.map((o,k)=>`
      <button class="opt" data-k="${k}"><span class="mk"><span>${LETTERS[k]}</span></span><span>${o.t}</span></button>`).join('')}</div>
    <div class="qfb" id="qfb"></div>`;
  quizArea.querySelectorAll('.opt').forEach(b=>b.addEventListener('click',()=>pick(b)));
}
function pick(btn){
  if(answered)return;answered=true;
  const item=QUIZ[qi];const k=+btn.dataset.k;
  const opts=quizArea.querySelectorAll('.opt');
  opts.forEach((o,idx)=>{
    o.disabled=true;
    if(item.opts[idx].ok)o.classList.add('correct');
  });
  if(item.opts[k].ok)score++;else btn.classList.add('wrong');
  const fb=document.getElementById('qfb');
  fb.innerHTML=item.fb;fb.classList.add('show');
  qNext.disabled=false;
}
qNext.addEventListener('click',()=>{
  if(qi<QUIZ.length-1){qi++;renderQ();}
  else showResult();
});
function showResult(){
  quizArea.style.display='none';quizNav.style.display='none';
  quizResult.classList.add('show');
  document.getElementById('qScore').textContent=`${score}/${QUIZ.length}`;
  const v=score===QUIZ.length?"Prospector de elite. Você domina o método Wizo de ponta a ponta."
    :score>=QUIZ.length-1?"Muito bem! Você já pensa em estratégia. Revise um módulo e fecha tudo."
    :score>=2?"Bom começo. Volte à trilha para afinar abordagem e follow-up."
    :"Sem problema — é exatamente por isso que a trilha existe. Comece pelo Módulo 00.";
  document.getElementById('qVerdict').textContent=v;
}
document.getElementById('qRetry').addEventListener('click',()=>{
  qi=0;score=0;quizResult.classList.remove('show');
  quizArea.style.display='';quizNav.style.display='';renderQ();
});
renderQ();

/* ---------------- SCRIPTS ---------------- */
const tabsEl=document.getElementById('scriptTabs');
const panelsEl=document.getElementById('scriptPanels');
SCRIPTS.forEach((s,i)=>{
  const tab=document.createElement('button');
  tab.className='tab'+(i===0?' active':'');
  tab.textContent=s.tab;tab.dataset.i=i;tab.setAttribute('role','tab');
  tabsEl.appendChild(tab);

  const panel=document.createElement('div');
  panel.className='script'+(i===0?' active':'');panel.dataset.i=i;
  panel.innerHTML=`
    <div class="sh"><b>${s.tab}</b><span class="goal">Objetivo: ${s.goal}</span></div>
    <div class="bubble">${s.msgs.map(m=>`<div class="msg ${m.alt?'alt':''}"><span class="who">${m.who}</span>${m.t}</div>`).join('')}</div>
    <div class="copy-row"><button class="copy-btn" data-i="${i}">Copiar script</button></div>`;
  panelsEl.appendChild(panel);
});
tabsEl.addEventListener('click',e=>{
  const tab=e.target.closest('.tab');if(!tab)return;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.script').forEach(p=>p.classList.remove('active'));
  tab.classList.add('active');
  document.querySelector(`.script[data-i="${tab.dataset.i}"]`).classList.add('active');
});
panelsEl.addEventListener('click',e=>{
  const btn=e.target.closest('.copy-btn');if(!btn)return;
  const s=SCRIPTS[+btn.dataset.i];
  const text=s.msgs.map(m=>m.t).join('\n\n');
  navigator.clipboard?.writeText(text).then(()=>{
    btn.textContent='✓ Copiado!';setTimeout(()=>btn.textContent='Copiar script',1600);
  }).catch(()=>{btn.textContent='Selecione e copie';});
});

/* ---------------- REVEAL ---------------- */
const io=new IntersectionObserver(es=>{
  es.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}});
},{threshold:.12});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

// init trajectory once layout settled
requestAnimationFrame(updateProgress);
</script>
</body>
